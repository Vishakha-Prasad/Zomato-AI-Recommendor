{
  "builds": [
    {
      "src": "phase_3_frontend_app/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "phase_3_frontend_app/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(?:static|assets)/(.*)",
      "dest": "/phase_3_frontend_app/public/static/$1"
    },
    {
      "src": "/",
      "dest": "/phase_3_frontend_app/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "phase_3_frontend_app/index.py"
    }
  ],
  "functions": {
    "phase_3_frontend_app/index.py": {
      "includeFiles": "phase_1_data_pipeline/data/**"
    }
  }
}